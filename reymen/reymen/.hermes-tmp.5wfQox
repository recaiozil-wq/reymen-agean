#!/usr/bin/env python3
"""ReYMeN Agent CLI launcher.

Mirrors Hermes' ``hermes-agent/hermes`` entry point.
"""
import sys
from pathlib import Path

# Proje kokunu sys.path'e ekle (reymen/reymen → .. → proje koku)
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

if __name__ == "__main__":
    from reymen_launcher import main
    main()
