# ReYMeN Agent — Örnek Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp kendi token'larınızı girin.

# Telegram Bot Token'ları
TELEGRAM_BOT_TOKEN_PASA_38=your_token_here
TELEGRAM_BOT_TOKEN_KIRAL38=your_token_here
TELEGRAM_BOT_TOKEN_REYMEN=your_token_here

# LLM API Anahtarları
DEEPSEEK_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# Web Search (opsiyonel)
# FIRECRAWL_API_KEY=your_key_here
# BRAVE_API_KEY=your_key_here

# Varsayılan bot
# BOT_TOKEN=your_token_here
