# ReYMeN Ajan - Ornek .env
# Kopyala: cp .env.example .env

# ── LLM / AI ───────────────────────────────────────────────────────────
# https://platform.deepseek.com/ adresinden API key al
DEEPSEEK_API_KEY=***
# Model (istege bagli, varsayilan: deepseek-v4-flash)
# DEEPSEEK_MODEL=deepseek-v4-pro

# ── Discord Bot ────────────────────────────────────────────────────────
# https://discord.com/developers/applications -> Bot -> Token
DISCORD_BOT_TOKEN=***
# Varsayilan kanal ID'si (opsiyonel)
# DISCORD_CHANNEL_ID=123456789012345678

# ── E-posta (SMTP) ─────────────────────────────────────────────────────
# Gmail ornegi: smtp.gmail.com:465 (uygulama sifresi kullanin)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=ornek@gmail.com
EMAIL_PASS=***

# ── Telegram Bot (mevcut) ──────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=***
# TELEGRAM_CHAT_ID=***

# ── WhatsApp (Twilio) ───────────────────────────────────────────────────
# https://console.twilio.com -> Account -> API Credentials
WHATSAPP_ACCOUNT_SID=***
WHATSAPP_AUTH_TOKEN=***
# WHATSAPP_API_KEY=*** (WHATSAPP_AUTH_TOKEN ile ayni, alias)
# Twilio'dan alinan WhatsApp numarasi (whatsapp:+1415...)
WHATSAPP_NUMBER=***

# ── Slack (Incoming Webhook) ───────────────────────────────────────────
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=***
