# ReYMeN Agent -- Environment Variables (Example)
# Copy: cp .env.example .env
# Edit: Fill in your API keys

# === REQUIRED ===
# DeepSeek API key (primary LLM)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# === OPTIONAL PROVIDERS ===
# OPENROUTER_API_KEY=your_openrouter_key
# GROQ_API_KEY=your_groq_key
# XAI_API_KEY=your_xai_key
# XIAOMI_API_KEY=your_xiaomi_key

# === TELEGRAM ===
# Bot token'ları aşağıya ekleyin (her bot için ayrı profil)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Güvenlik: false = sadece ALLOWED_CHATS'teki kullanıcılar erişebilir
GATEWAY_ALLOW_ALL_USERS=false
# Virgülle ayrılmış Telegram kullanıcı ID'leri (whitelist)
# ALLOWED_CHATS=6328823909

# === ONAY MEKANİZMASI ===
# approvals.mode: gateway (aktif)
# destructive_slash_confirm: true (yıkıcı komutlar onay ister)
# cron_mode: deny (cron job'lar asla onaysız çalışamaz)

# === MODEL CONFIG ===
# REYMEN_PROVIDER=deepseek
# REYMEN_MODEL=deepseek-v4-flash

# === GATEWAYS ===
# SLACK_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# MATRIX_HOMESERVER=
# MATRIX_ACCESS_TOKEN=

# === WEB UI ===
# SECRET_KEY=
# ADMIN_CHAT_IDS=

# === DEVELOPMENT ===
# LOG_LEVEL=INFO
# DEBUG=false
