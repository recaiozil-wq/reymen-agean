[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.backends._legacy:_Backend"

[project]
name = "deepseek-ajan"
version = "1.0.0"
description = "Guvenli, full yetkili, ogrenen AI agent for DeepSeek-v4-flash"
readme = "README.md"
requires-python = ">=3.10"
license = {text = "MIT"}
keywords = ["ai", "agent", "deepseek", "cli"]
dependencies = [
    "openai>=1.0",
]
classifiers = [
    "Development Status :: 4 - Beta",
    "Environment :: Console",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: MIT License",
    "Programming Language :: Python :: 3",
]

[project.urls]
Homepage = "https://github.com/recaiozil-wq/deepseek-ajan"

[project.scripts]
deepseek-ajan = "deepseek_ajan.cli:main"
