# llm_provider/.env.example
# Kopyala: cp .env.example .env

# Birincil provider (lmstudio / openai / anthropic / groq / ollama)
LLM_DEFAULT_PROVIDER=lmstudio

# LM Studio (localhost — API key gerekmez)
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=cognitivecomputations.dolphin3.0-llama3.1-8b

# OpenAI (opsiyonel)
OPENAI_API_KEY=sk-...

# Anthropic (opsiyonel)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (ucretsiz, hizli — groq.com/keys)
GROQ_API_KEY=gsk_...

# DeepSeek (opsiyonel)
DEEPSEEK_API_KEY=sk-...
