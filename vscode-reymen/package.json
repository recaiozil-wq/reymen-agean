{
  "name": "reymen-agent",
  "displayName": "ReYMeN Agent",
  "description": "ReYMeN AI Agent VS Code entegrasyonu - MCP uzerinden sohbet ve komut",
  "version": "1.0.0",
  "publisher": "reymen",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Chat",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": ["reymen", "ai", "agent", "mcp", "sohbet"],
  "icon": "icon.png",
  "activationEvents": [
    "onCommand:reymen.chat",
    "onCommand:reymen.askSelection"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "reymen.chat",
        "title": "ReYMeN: Sohbet",
        "category": "ReYMeN"
      },
      {
        "command": "reymen.askSelection",
        "title": "ReYMeN: Secili Kodu Sor",
        "category": "ReYMeN"
      },
      {
        "command": "reymen.status",
        "title": "ReYMeN: Durum Kontrol",
        "category": "ReYMeN"
      }
    ],
    "keybindings": [
      {
        "command": "reymen.askSelection",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "ReYMeN",
      "properties": {
        "reymen.mcpUrl": {
          "type": "string",
          "default": "http://localhost:9000",
          "description": "ReYMeN MCP sunucu adresi"
        },
        "reymen.model": {
          "type": "string",
          "default": "default",
          "description": "Varsayilan model"
        }
      }
    }
  }
}
