# =============================================================================
# 🌐 OAuth 2.0 — Çevresel Değişkenler
# =============================================================================
# Bu değişkenler reymen/guvenlik/oauth_sistemi.py ve
# reymen/guvenlik/oauth_servis.py tarafından kullanılır.
#
# Google Cloud Console'da OAuth 2.0 Client ID oluşturun:
#   https://console.cloud.google.com/apis/credentials
# (Web uygulaması türü, Authorized redirect URI'yi ekleyin)
#
# GitHub OAuth App:
#   https://github.com/settings/developers
#
# Discord Application:
#   https://discord.com/developers/applications
# =============================================================================

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Gmail, Drive, Calendar API'leri için OAuth 2.0 Client ID ve Secret
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret
# Callback URL (opsiyonel, varsayılan: http://localhost:5000/auth/callback/google)
# GOOGLE_REDIRECT_URI=http://localhost:5000/auth/callback/google

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
# Repo, user, workflow yönetimi için GitHub OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# Callback URL (opsiyonel, varsayılan: http://localhost:5000/auth/callback/github)
# GITHUB_REDIRECT_URI=http://localhost:5000/auth/callback/github

# ── Discord OAuth ────────────────────────────────────────────────────────────
# identify, email scope'ları ile Discord girişi
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Discord Bot Token (bot auth için — OAuth'dan farklı)
# DISCORD_BOT_TOKEN=your_discord_bot_token
# Callback URL (opsiyonel, varsayılan: http://localhost:5000/auth/callback/discord)
# DISCORD_REDIRECT_URI=http://localhost:5000/auth/callback/discord

# ── Genel OAuth Ayarları ─────────────────────────────────────────────────────
# Varsayılan callback base URL (provider'a özel redirect_uri yoksa kullanılır)
# OAUTH_CALLBACK_BASE=http://localhost:5000
