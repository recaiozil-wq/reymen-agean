# ─── ReYMeN Agent — Örnek Ortam Değişkenleri ──────────────────────
# Bu dosyayı proje köküne .env olarak kopyalayıp kendi token'larınızı girin.
#   cp config/.env.example .env
#
# Tüm değişkenler zorunlu değildir; sadece kullanacağınız platformların
# token'larını doldurmanız yeterlidir.

# ─── Zorunlu: LLM Sağlayıcı ─────────────────────────────────────
# En az BİR tane ayarlanmalıdır. DeepSeek önerilir (en ucuz).
DEEPSEEK_API_KEY=sk-you...key
#OPENAI_API_KEY=sk-you...key
#ANTHROPIC_API_KEY=sk-ant...key
#XAI_API_KEY=your-xai-grok-key
#OPENROUTER_API_KEY=sk-or-...key
#GROQ_API_KEY=gsk-your-groq-key

# ─── Xiaomi Mimo (opsiyonel yedek) ──────────────────────────────
# Xiaomi Mimo API — config.yaml fallback_providers'da kullanılır
#XIAOMI_API_KEY=your-xiaomi-api-key

# ─── GitHub Token (opsiyonel, push/self-update için) ────────────
# Repo'ya otomatik push, self-update ve nightly işlemleri için
#GITHUB_TOKEN=ghp_your_github_token_here

# ─── Telegram Bot Token'ları ─────────────────────────────────────
# @BotFather üzerinden bot oluşturup token'ları alın
PASA38_BOT_TOKEN=your-pasa38-bot-token
REYMEN_BOT_TOKEN=your-reymen-bot-token
KIRAL38_BOT_TOKEN=your-kiral38-bot-token

# ─── Discord (opsiyonel) ─────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id

# ─── Gateway Platformları (opsiyonel) ────────────────────────────
# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Microsoft Teams
TEAMS_TENANT_ID=your-tenant-id
TEAMS_CLIENT_ID=your-client-id
TEAMS_CLIENT_SECRET=your-client-secret

# Home Assistant
HASS_TOKEN=your-long-lived-access-token
HASS_HOST=http://homeassistant.local:8123

# Signal
SIGNAL_URL=http://localhost:8080
SIGNAL_NUMBER=+905****5555

# Matrix
MATRIX_HOMESERVER_URL=https://matrix.example.com
MATRIX_ACCESS_TOKEN=your-matrix-token

# DingTalk / Feishu / WeCom
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
FEISHU_APP_ID=cli_your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# Google Chat (opsiyonel)
#GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/xxxx/messages

# ─── Uzak Ortamlar (opsiyonel) ──────────────────────────────────
# SSH
SSH_HOST=your-server.com
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=
SSH_KEY_PATH=~/.ssh/id_rsa

# Daytona Cloud Sandbox
DAYTONA_API_KEY=your-daytona-api-key
DAYTONA_TARGET=us

# ─── Auth Sistemi ────────────────────────────────────────────────
# Web UI JWT kimlik doğrulama için gizli anahtar (config.yaml > auth.jwt_secret_env)
# Oluşturmak için: python -c "import secrets; print(secrets.token_hex(32))"
REYMEN_JWT_SECRET=your-jwt-secret-here-min-32-chars

# ─── OpenTelemetry / Observability (opsiyonel) ──────────────────
# Langfuse OTLP tracing — config.yaml > observability bölümü
#LANGFUSE_PUBLIC_KEY=pk-lf-xxx
#LANGFUSE_SECRET_KEY=sk-lf-xxx

# ─── Web Arama (opsiyonel) ──────────────────────────────────────
# FIRECRAWL_API_KEY=sk-your-key-here
# BRAVE_API_KEY=your-brave-search-key-here
